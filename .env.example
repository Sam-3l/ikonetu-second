# ════════════════════════════════════════════════════════════
# IkonetU — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# ════════════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Cloud SQL (PostgreSQL 15) ─────────────────────────────────
# Get from: Google Cloud Console → SQL → your instance → Overview
DB_HOST=YOUR_CLOUD_SQL_PUBLIC_IP
DB_PORT=5432
DB_NAME=ikonetu
DB_USER=ikonetu_app
DB_PASSWORD=YOUR_DB_PASSWORD
DB_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── Redis ─────────────────────────────────────────────────────
# Local development: redis://localhost:6379
# Production: Use Cloud Memorystore URL
REDIS_URL=redis://localhost:6379

# ── JWT (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=GENERATE_64_CHAR_HEX_AND_PASTE_HERE
JWT_REFRESH_SECRET=GENERATE_DIFFERENT_64_CHAR_HEX_HERE
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ── SendGrid ──────────────────────────────────────────────────
# Get from: app.sendgrid.com/settings/api_keys
# IMPORTANT: Regenerate if you shared the old key anywhere
SENDGRID_API_KEY=SG.YOUR_NEW_API_KEY_HERE
SENDGRID_FROM_EMAIL=noreply@ikonetu.com
SENDGRID_FROM_NAME=IkonetU

# ── Google Cloud ──────────────────────────────────────────────
# Point to your downloaded service account JSON file
GOOGLE_CLOUD_PROJECT=ikonetu
GOOGLE_APPLICATION_CREDENTIALS=./ikonetu-service-account.json

# ── Cloud Storage ─────────────────────────────────────────────
GCS_BUCKET=ikonetu-media-prod
GCS_REGION=europe-west2

# ── Cloud Pub/Sub ─────────────────────────────────────────────
PUBSUB_PROJECT_ID=ikonetu

# ── Firebase ──────────────────────────────────────────────────
# VAPID key from: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
FIREBASE_VAPID_KEY=YOUR_VAPID_KEY_HERE
FIREBASE_HOSTING_SITE=ikonetu
FIREBASE_PROJECT_NUMBER=714358463817

# ── Gemini AI ─────────────────────────────────────────────────
GEMINI_MODEL=gemini-1.5-pro
GEMINI_LOCATION=europe-west2

# ── Google Maps ───────────────────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials
# Restrict to: Maps JavaScript, Places, Geocoding, Directions, Distance Matrix
GOOGLE_MAPS_API_KEY=AIzaSyCkrxPOO5e825qrULPYKR9TfQROauD2qiw

# ── BigQuery ──────────────────────────────────────────────────
BIGQUERY_DATASET=ikonetu_analytics
BIGQUERY_PROJECT=ikonetu

# ── Stripe (USE TEST KEYS DURING DEVELOPMENT) ─────────────────
# Get test keys from: dashboard.stripe.com/test/apikeys
# NEVER use sk_live_ during development
STRIPE_SECRET_KEY=sk_test_YOUR_TEST_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_TEST_PUBLISHABLE_KEY
# Get from: stripe listen --forward-to localhost:3001/api/v1/billing/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_CONNECT_CLIENT_ID=ca_YOUR_CONNECT_CLIENT_ID

# ── Paystack ──────────────────────────────────────────────────
# Get from: dashboard.paystack.com/settings/developer
PAYSTACK_SECRET_KEY=sk_test_c573782486445be32e855fa2549adba424a7874c
PAYSTACK_PUBLIC_KEY=pk_test_17fb88031c395028b0e4b2be09ed100856b88f39
# Choose any strong string — you verify this on incoming webhooks
PAYSTACK_WEBHOOK_SECRET=CHOOSE_A_STRONG_SECRET_STRING

# ── Encryption (AES-256) ──────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=GENERATE_64_CHAR_HEX_HERE
ENCRYPTION_KEY_VERSION=1

# ── Hard Guards — DO NOT CHANGE THESE ─────────────────────────
# R12: commission is always exactly 9.5%
R12_COMMISSION_PCT=9.5
# R11: loan disbursement fee — ON HOLD until legal clearance
R11_ACTIVE=false
# Dark mode: permanently disabled — IkonetU design principle
DARK_MODE_ENABLED=false

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── OTP Config ────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_LOCKOUT_SECONDS=1800

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Service URLs ──────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
SCORING_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_URL=http://localhost:3008

# ── Application URL ───────────────────────────────────────────
# Used by Stripe Connect OAuth redirects and Paystack callback URLs
APP_URL=http://localhost:5173

# ── Sentry Error Tracking ─────────────────────────────────────
# Get from: sentry.io → New Project → Node.js → DSN
# Leave blank in development to disable Sentry
SENTRY_DSN=

# Frontend Sentry DSN (can be same project with different DSN)
VITE_SENTRY_DSN=

# ── Stripe Connect (R12 provider payouts) ─────────────────────
# Get from: dashboard.stripe.com/settings/connect
# Required before any R12 marketplace booking can pay out to providers
STRIPE_CONNECT_CLIENT_ID=ca_YOUR_CONNECT_CLIENT_ID

# ── Companies House API (UK registry verification) ───────────
# Get from: developer-specs.company-information.service.gov.uk
# Free tier: 600 requests/day — sufficient for MVP
COMPANIES_HOUSE_API_KEY=YOUR_COMPANIES_HOUSE_KEY

# ── Git SHA (injected by CI, used by Sentry for release tracking)
# Do not set manually — CI sets this automatically
# GIT_SHA=abc123...
