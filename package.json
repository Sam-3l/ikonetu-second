{
  "name": "ikonetu",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "concurrently \"npm run dev -w services/auth-service\" \"npm run dev -w services/user-service\"",
    "migrate": "npm run migrate -w packages/database",
    "migrate:rollback": "npm run migrate:rollback -w packages/database",
    "test": "jest --runInBand",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:load": "k6 run tests/load/platform.load.js",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0",
    "typescript": "^5.4.0",
    "@playwright/test": "^1.43.0",
    "opossum": "^8.1.0",
    "@types/opossum": "^8.1.0",
    "@sentry/node": "^8.0.0",
    "@sentry/profiling-node": "^8.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/services",
      "<rootDir>/packages"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "services/*/src/**/*.ts",
      "packages/*/src/**/*.ts",
      "!**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  }
}